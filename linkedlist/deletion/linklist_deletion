    fifth= (struct node *)malloc(sizeof(struct node));
    head ->data=5;
    head ->next =second;

    second ->data=10;
    second ->next=third;

    third->data=15;
    third->next=forth;

    forth ->data=20;
    forth ->next=fifth;
    
    fifth ->data=25;
    fifth ->next =NULL;
    show_deletion(head);
    head = printt_node(head );
    printf( " \nafter deletion\n");
    show_deletion(head);
    return 0;
}